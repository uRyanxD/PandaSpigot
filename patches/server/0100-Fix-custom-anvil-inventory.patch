     }
@@ -222,7 +230,7 @@ public class CraftContainer extends Container {
 
         for (row = 0; row < 3; ++row) {
             for (col = 0; col < 3; ++col) {
-                this.a(new Slot(top, col + row * 3, 61 + col * 18, 17 + row * 18));
+                this.a(new Slot(top, col + row * 3, 62 + col * 18, 17 + row * 18));
             }

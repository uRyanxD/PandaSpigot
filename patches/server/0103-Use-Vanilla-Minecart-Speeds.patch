@@ -30,9 +30,11 @@ public abstract class EntityMinecartAbstract extends Entity implements INamableT
     private double derailedX = 0.5;
     private double derailedY = 0.5;
     private double derailedZ = 0.5;
-    private double flyingX = 0.95;
-    private double flyingY = 0.95;
-    private double flyingZ = 0.95;
+    // PandaSpigot start - Restore Vanilla Precision
+    private double flyingX = 0.949999988079071D;
+    private double flyingY = 0.949999988079071D;
+    private double flyingZ = 0.949999988079071D;
